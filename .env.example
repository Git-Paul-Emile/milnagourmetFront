VITE_API_URL=http://localhost:3000

# Vidéo de fond du hero (facultatif).
# Doit pointer vers un fichier vidéo .mp4 accessible publiquement, et non
# vers une page web. Si la variable est absente, le composant utilise le
# fichier local front/public/videos/hero-yaourt.mp4, et à défaut l'image
# de bannière en repli.
# VITE_HERO_VIDEO_URL=https://exemple.com/chemin/vers/video.mp4
